# qbt-jelly-mover configuration. Copy to .env and fill in.

# qBittorrent WebUI (v5.x API-key auth)
QBT_URL=http://192.168.0.42:8082
QBT_API_KEY=qbt_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Path prefix as qBittorrent (on the NAS) sees its downloads,
# and where that same folder is mounted on this machine.
QBT_SAVE_PATH_PREFIX=/downloads
LOCAL_DOWNLOADS_DIR=/mnt/downloads

# Jellyfin library roots (NAS mounts)
MOVIES_DIR=/mnt/jelly/movies
TV_DIR=/mnt/jelly/tv
# Where media goes when classification confidence is low.
# Leave empty to leave such torrents in the downloads folder instead.
NEEDS_REVIEW_DIR=/mnt/jelly/needs_review

# Polling
POLL_INTERVAL=60
# Only process torrents in this qBittorrent category (empty = all torrents)
QBT_CATEGORY=

# Claude CLI (use an absolute path when running under systemd)
CLAUDE_BIN=claude
CLAUDE_MODEL=sonnet
CLAUDE_TIMEOUT=180
CLAUDE_MAX_BUDGET_USD=1.00

# Retry/bookkeeping
MAX_ATTEMPTS=3
STATE_FILE=~/.local/state/qbt-jelly-mover/state.json
# After all files moved out, rmdir the empty folder husk left in downloads
CLEANUP_EMPTY_DIRS=true
